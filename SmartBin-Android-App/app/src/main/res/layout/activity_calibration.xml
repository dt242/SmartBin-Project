<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="48dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_dark"
                android:elevation="8dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:shadowColor="#40000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="8"
                android:text="@string/calibration_title"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_pill_white"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/lid_sensor_settings"
                android:textColor="#2D3142"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sensor_trigger_dist"
                android:textColor="#4F5D75" />

            <TextView
                android:id="@+id/tvTriggerDistVal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                tools:text="20 cm"
                android:textColor="#00A896"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbTriggerDistance"
                android:progress="3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:max="9"
                android:progressTint="#00A896"
                android:thumbTint="#00A896" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lid_opening_angle"
                android:textColor="#4F5D75" />

            <TextView
                android:id="@+id/tvAngleVal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                tools:text="90°"
                android:textColor="#00A896"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbOpenAngle"
                android:progress="6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:max="6"
                android:progressTint="#00A896"
                android:thumbTint="#00A896" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/open_duration"
                android:textColor="#4F5D75" />

            <TextView
                android:id="@+id/tvDurationVal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                tools:text="4 sec"
                android:textColor="#00A896"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbOpenDuration"
                android:progress="3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="7"
                android:progressTint="#00A896"
                android:thumbTint="#00A896" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_pill_white"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/led_status_thresholds"
                android:textColor="#2D3142"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yellow_led_thresh"
                android:textColor="#4F5D75" />

            <TextView
                android:id="@+id/tvYellowVal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                tools:text="50 %"
                android:textColor="#FFB300"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbYellowThresh"
                android:progress="4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:max="7"
                android:progressTint="#FFB300"
                android:thumbTint="#FFB300" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/red_led_thresh"
                android:textColor="#4F5D75" />

            <TextView
                android:id="@+id/tvRedVal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                tools:text="80 %"
                android:textColor="#F44336"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbRedThresh"
                android:progress="6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="7"
                android:progressTint="#F44336"
                android:thumbTint="#F44336" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_pill_white"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/sound_alerts_title"
                android:textColor="#2D3142"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swBeepOpen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/beep_on_open"
                android:textColor="#4F5D75" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swBeepFull"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/beep_when_full"
                android:textColor="#4F5D75" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swBeepGas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/beep_on_gas"
                android:textColor="#4F5D75" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fire_alarm_disclaimer"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:textStyle="italic" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveCalibration"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#2D3142"
            android:text="@string/btn_save_apply"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:cornerRadius="32dp" />

    </LinearLayout>
</ScrollView>